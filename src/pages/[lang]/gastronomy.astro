---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import { TRANSLATIONS, DEFAULT_LANGUAGE, LANGUAGES, type Language } from "../../i18n/translations";
import "../../styles/global.css";

// Get language from URL params
const { lang } = Astro.params;
const currentLang: Language = lang && Object.values(LANGUAGES).includes(lang as Language) 
  ? (lang as Language) 
  : DEFAULT_LANGUAGE;
const t = TRANSLATIONS[currentLang];
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return [
    { params: { lang: LANGUAGES.ES } },
    { params: { lang: LANGUAGES.PT } },
    { params: { lang: LANGUAGES.EN } },
  ];
}
---

<Layout title={`${t.nav.gastronomy} - Brasil`} lang={currentLang}>
  <!-- Language switcher for mobile (fixed position) -->
  <div class="fixed bottom-4 right-4 z-50 md:hidden">
    <LanguageSwitcher currentLang={currentLang} />
  </div>

  <Navbar variant="glass-pill" activeLink="gastronomy" lang={currentLang} />

  <main>
    <!-- Hero Section: Uma Jornada Culinária pelo Brasil -->
    <section class="relative min-h-[90vh] flex items-center px-6 lg:px-20 py-20 overflow-hidden">
      <div class="container mx-auto grid lg:grid-cols-12 gap-12 items-center relative z-10">
        <div class="lg:col-span-6 space-y-8">
          <span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container font-label text-xs font-bold tracking-widest uppercase">{t.gastronomy.hero.badge}</span>
          <h1 class="text-6xl lg:text-8xl font-black leading-[0.9] text-primary tracking-tighter">{t.gastronomy.hero.title}</h1>
          <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed">{t.gastronomy.hero.description}</p>
        </div>
        <div class="lg:col-span-6 relative">
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <img
                alt="Traditional Brazilian Feijoada stew in clay pot"
                class="w-full aspect-[4/5] object-cover rounded-xl editorial-shadow"
                src={`${base}images/hero-feijoada.png`}
              />
              <img
                alt="Classic Brazilian Churrasco grilled meat skewers"
                class="w-full aspect-square object-cover rounded-xl editorial-shadow translate-x-12"
                src={`${base}images/hero-churrasco.png`}
              />
            </div>
            <div class="pt-12">
              <img
                alt="Fresh Brazilian Moqueca seafood stew simmering"
                class="w-full aspect-[3/4] object-cover rounded-xl editorial-shadow"
                src={`${base}images/hero-moqueca.png`}
              />
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-tertiary-container/20 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </section>

    <!-- Regional Flavors: Bento Grid -->
    <section class="py-24 bg-surface-container-low px-6 lg:px-20 rounded-[3rem]">
      <div class="container mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
          <div class="max-w-2xl">
            <h2 class="text-4xl lg:text-6xl font-black text-primary leading-tight tracking-tight">{t.gastronomy.regions.title}</h2>
            <p class="text-lg text-on-surface-variant mt-4">{t.gastronomy.regions.description}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto">
          <!-- Amazonian -->
          <div class="md:col-span-8 group relative overflow-hidden rounded-xl bg-surface-container h-[400px]">
            <img
              alt="Exotic Amazonian fruits and river fish"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              src={`${base}images/amazonian.png`}
            />
            <div class="absolute inset-0 bg-linear-to-t from-primary/80 to-transparent"></div>
            <div class="absolute bottom-0 p-10">
              <h3 class="text-3xl font-bold text-on-primary">{t.gastronomy.regions.amazon.title}</h3>
              <p class="text-on-primary/80 mt-2 max-w-md">{t.gastronomy.regions.amazon.description}</p>
              <div class="mt-6 flex gap-2">
                <span class="px-3 py-1 bg-white/20 backdrop-blur-md rounded-full text-xs font-bold text-on-primary uppercase tracking-widest">{t.gastronomy.regions.amazon.tags[0]}</span>
                <span class="px-3 py-1 bg-white/20 backdrop-blur-md rounded-full text-xs font-bold text-on-primary uppercase tracking-widest">{t.gastronomy.regions.amazon.tags[1]}</span>
              </div>
            </div>
          </div>
          <!-- Southern -->
          <div class="md:col-span-4 group relative overflow-hidden rounded-xl bg-tertiary h-[400px]">
            <img
              alt="Authentic Southern Brazilian Churrasco grill"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60"
              src={`${base}images/southern-churrasco.png`}
            />
            <div class="absolute inset-0 flex flex-col justify-end p-10">
              <h3 class="text-3xl font-bold text-on-tertiary">{t.gastronomy.regions.south.title}</h3>
              <p class="text-on-tertiary/80 mt-2">{t.gastronomy.regions.south.description}</p>
            </div>
          </div>
          <!-- Northeastern -->
          <div class="md:col-span-4 group relative overflow-hidden rounded-xl bg-secondary-container h-[400px]">
            <img
              alt="Spicy Northeastern seafood dish with dendê oil"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-70"
              src={`${base}images/northeastern.png`}
            />
            <div class="absolute inset-0 flex flex-col justify-end p-10">
              <h3 class="text-3xl font-bold text-on-secondary-container">{t.gastronomy.regions.northeast.title}</h3>
              <p class="text-on-secondary-container/80 mt-2">{t.gastronomy.regions.northeast.description}</p>
            </div>
          </div>
          <!-- Minas Gerais -->
          <div class="md:col-span-8 group relative overflow-hidden rounded-xl bg-surface-container-highest h-[400px]">
            <img
              alt="Brazilian Pão de Queijo and artisanal cheese"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              src={`${base}images/minas-cheese.png`}
            />
            <div class="absolute inset-0 bg-linear-to-tr from-secondary/60 to-transparent"></div>
            <div class="absolute bottom-0 right-0 p-10 text-right">
              <h3 class="text-3xl font-bold text-on-surface">{t.gastronomy.regions.minas.title}</h3>
              <p class="text-on-surface-variant mt-2 max-w-sm ml-auto">{t.gastronomy.regions.minas.description}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Art of the Caipirinha -->
    <section class="py-32 px-6 lg:px-20 overflow-hidden">
      <div class="container mx-auto grid lg:grid-cols-2 gap-20 items-center">
        <div class="relative">
          <div class="w-full aspect-square rounded-full border-[20px] border-secondary-container/30 absolute -top-10 -left-10 animate-pulse"></div>
          <img
            alt="A refreshing lime Caipirinha with ice and sugar"
            class="w-full aspect-[4/5] object-cover rounded-[3rem] editorial-shadow relative z-10"
            src={`${base}images/caipirinha.png`}
          />
          <div class="absolute -bottom-6 -right-6 glass-panel p-8 rounded-2xl editorial-shadow z-20 max-w-[200px]">
            <span class="text-primary font-bold text-4xl block mb-2">100%</span>
            <span class="text-sm font-label uppercase font-bold tracking-widest text-on-surface-variant">{t.gastronomy.caipirinha.badge}</span>
          </div>
        </div>
        <div class="space-y-10">
          <h2 class="text-5xl lg:text-7xl font-black text-primary leading-tight">{t.gastronomy.caipirinha.title}</h2>
          <p class="text-xl text-on-surface-variant leading-relaxed">{t.gastronomy.caipirinha.description}</p>
          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-secondary-container flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-on-secondary-container" style="font-variation-settings: 'FILL' 1;">eco</span>
              </div>
              <div>
                <h4 class="font-bold text-lg">{t.gastronomy.caipirinha.feature1.title}</h4>
                <p class="text-on-surface-variant">{t.gastronomy.caipirinha.feature1.description}</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">ac_unit</span>
              </div>
              <div>
                <h4 class="font-bold text-lg">{t.gastronomy.caipirinha.feature2.title}</h4>
                <p class="text-on-surface-variant">{t.gastronomy.caipirinha.feature2.description}</p>
              </div>
            </li>
          </ul>
          <button class="flex items-center gap-3 group">
            <span class="w-12 h-12 rounded-full border-2 border-primary flex items-center justify-center group-hover:bg-primary group-hover:text-on-primary transition-all">
              <span class="material-symbols-outlined">arrow_forward</span>
            </span>
            <span class="font-label font-bold text-primary tracking-widest uppercase text-sm">{t.gastronomy.caipirinha.cta}</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Featured Experiences: Top 5 Gastronomic Tours -->
    <section class="py-24 bg-tertiary px-6 lg:px-20">
      <div class="container mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-6xl font-black text-on-tertiary mb-6">{t.gastronomy.tours.title}</h2>
          <p class="text-tertiary-fixed-dim max-w-2xl mx-auto text-lg">{t.gastronomy.tours.description}</p>
        </div>
        <div class="flex flex-nowrap overflow-x-auto gap-8 pb-12 no-scrollbar">
          <!-- Tour 1 -->
          <div class="min-w-[320px] lg:min-w-[400px] bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
            <img
              alt="Lush coffee plantation in Minas Gerais mountains"
              class="w-full h-48 object-cover rounded-xl mb-6"
              src={`${base}images/tour-coffee.png`}
            />
            <span class="text-secondary-fixed text-xs font-bold tracking-widest uppercase">{t.gastronomy.tours.tour1.location}</span>
            <h3 class="text-2xl font-bold text-white mt-2">{t.gastronomy.tours.tour1.title}</h3>
            <p class="text-tertiary-fixed-dim mt-4">{t.gastronomy.tours.tour1.description}</p>
            <div class="mt-8 flex justify-between items-center">
              <span class="text-white font-bold">{t.gastronomy.tours.tour1.duration}</span>
              <span class="material-symbols-outlined text-secondary-fixed">arrow_outward</span>
            </div>
          </div>
          <!-- Tour 2 -->
          <div class="min-w-[320px] lg:min-w-[400px] bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
            <img
              alt="Street food market in Salvador Bahia"
              class="w-full h-48 object-cover rounded-xl mb-6"
              src={`${base}images/northeastern.png`}
            />
            <span class="text-secondary-fixed text-xs font-bold tracking-widest uppercase">{t.gastronomy.tours.tour2.location}</span>
            <h3 class="text-2xl font-bold text-white mt-2">{t.gastronomy.tours.tour2.title}</h3>
            <p class="text-tertiary-fixed-dim mt-4">{t.gastronomy.tours.tour2.description}</p>
            <div class="mt-8 flex justify-between items-center">
              <span class="text-white font-bold">{t.gastronomy.tours.tour2.duration}</span>
              <span class="material-symbols-outlined text-secondary-fixed">arrow_outward</span>
            </div>
          </div>
          <!-- Tour 3 -->
          <div class="min-w-[320px] lg:min-w-[400px] bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
            <img
              alt="Sophisticated fine dining restaurant in Sao Paulo"
              class="w-full h-48 object-cover rounded-xl mb-6"
              src={`${base}images/hero-christ.png`}
            />
            <span class="text-secondary-fixed text-xs font-bold tracking-widest uppercase">{t.gastronomy.tours.tour3.location}</span>
            <h3 class="text-2xl font-bold text-white mt-2">{t.gastronomy.tours.tour3.title}</h3>
            <p class="text-tertiary-fixed-dim mt-4">{t.gastronomy.tours.tour3.description}</p>
            <div class="mt-8 flex justify-between items-center">
              <span class="text-white font-bold">{t.gastronomy.tours.tour3.duration}</span>
              <span class="material-symbols-outlined text-secondary-fixed">arrow_outward</span>
            </div>
          </div>
          <!-- Tour 4 -->
          <div class="min-w-[320px] lg:min-w-[400px] bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
            <img
              alt="Exotic Amazonian fruits and ingredients"
              class="w-full h-48 object-cover rounded-xl mb-6"
              src={`${base}images/amazonian.png`}
            />
            <span class="text-secondary-fixed text-xs font-bold tracking-widest uppercase">{t.gastronomy.tours.tour4.location}</span>
            <h3 class="text-2xl font-bold text-white mt-2">{t.gastronomy.tours.tour4.title}</h3>
            <p class="text-tertiary-fixed-dim mt-4">{t.gastronomy.tours.tour4.description}</p>
            <div class="mt-8 flex justify-between items-center">
              <span class="text-white font-bold">{t.gastronomy.tours.tour4.duration}</span>
              <span class="material-symbols-outlined text-secondary-fixed">arrow_outward</span>
            </div>
          </div>
          <!-- Tour 5 -->
          <div class="min-w-[320px] lg:min-w-[400px] bg-white/5 backdrop-blur-md rounded-2xl p-6 border border-white/10">
            <img
              alt="Rio de Janeiro beach street food scene"
              class="w-full h-48 object-cover rounded-xl mb-6"
              src={`${base}images/rio-coastline.png`}
            />
            <span class="text-secondary-fixed text-xs font-bold tracking-widest uppercase">{t.gastronomy.tours.tour5.location}</span>
            <h3 class="text-2xl font-bold text-white mt-2">{t.gastronomy.tours.tour5.title}</h3>
            <p class="text-tertiary-fixed-dim mt-4">{t.gastronomy.tours.tour5.description}</p>
            <div class="mt-8 flex justify-between items-center">
              <span class="text-white font-bold">{t.gastronomy.tours.tour5.duration}</span>
              <span class="material-symbols-outlined text-secondary-fixed">arrow_outward</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer lang={currentLang} />
</Layout>
