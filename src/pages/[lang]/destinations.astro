---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import { TRANSLATIONS, DEFAULT_LANGUAGE, LANGUAGES, type Language } from "../../i18n/translations";
import "../../styles/global.css";

// Get language from URL params
const { lang } = Astro.params;
const currentLang: Language = lang && Object.values(LANGUAGES).includes(lang as Language)
  ? (lang as Language)
  : DEFAULT_LANGUAGE;
const t = TRANSLATIONS[currentLang];
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return [
    { params: { lang: LANGUAGES.ES } },
    { params: { lang: LANGUAGES.PT } },
    { params: { lang: LANGUAGES.EN } },
  ];
}
---

<Layout title={`${t.nav.destinations} - Brasil`} lang={currentLang}>
  <!-- Language switcher for mobile (fixed position) -->
  <div class="fixed bottom-4 right-4 z-50 md:hidden">
    <LanguageSwitcher currentLang={currentLang} />
  </div>

  <Navbar variant="glass-pill" activeLink="destinations" lang={currentLang} />

  <!-- Hero Section -->
  <header class="relative min-h-screen flex items-center pt-20 px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        alt="Lush Amazon rainforest canopy with a winding river"
        class="w-full h-full object-cover"
        src={`${base}images/amazona.png`}
      />
      <div class="absolute inset-0 bg-linear-to-b from-transparent via-transparent to-background/90"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-8">
        <h1 class="font-headline font-extrabold text-6xl md:text-8xl lg:text-9xl text-white tracking-tighter leading-[0.9] text-balance mb-8">
          {t.destinations.hero.title}<br />
          <span class="text-secondary-fixed">{t.destinations.hero.titleAccent}</span>
        </h1>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
          <button class="group relative bg-primary text-on-primary font-headline font-bold text-xl px-10 py-5 rounded-full overflow-hidden transition-all hover:scale-105 editorial-shadow"
          >
            <span class="relative z-10">{t.destinations.hero.cta}</span>
            <div class="absolute inset-0 bg-linear-to-r from-primary to-primary-container opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </button>
        </div>
      </div>
      <div class="lg:col-span-4 hidden lg:block">
        <div class="glass-effect p-8 rounded-xl editorial-shadow border border-white/20">
          <p class="font-headline text-2xl font-bold text-on-surface mb-4 italic">{t.destinations.hero.quote}</p>
          <p class="text-on-surface-variant font-body leading-relaxed">{t.destinations.hero.description}</p>
        </div>
      </div>
    </div>
  </header>

  <!-- Featured Destinations (Bento Grid) -->
  <section class="py-32 px-6 bg-surface">
    <div class="max-w-7xl mx-auto">
      <div class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div class="max-w-2xl">
          <span class="text-primary font-headline font-bold tracking-widest text-sm uppercase mb-4 block">{t.destinations.featured.subtitle}</span>
          <h2 class="text-5xl md:text-6xl font-headline font-extrabold text-on-surface tracking-tight">{t.destinations.featured.title}</h2>
        </div>
        <div class="flex gap-4">
          <span class="px-6 py-2 rounded-full bg-secondary-container text-on-secondary-container font-label font-bold text-sm">{t.destinations.featured.badge}</span>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:h-[800px]">
        <!-- Rio de Janeiro -->
        <div class="md:col-span-7 relative group overflow-hidden rounded-xl editorial-shadow">
          <img
            alt="Aerial view of Rio de Janeiro coastline with mountains and beaches"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src={`${base}images/rio-coastline.png`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-10 w-full">
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-primary/20 backdrop-blur-md text-primary-fixed px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">{t.destinations.rio.tag}</span>
            </div>
            <h3 class="text-4xl font-headline font-bold text-white mb-2">{t.destinations.rio.title}</h3>
            <p class="text-white/80 max-w-md mb-6">{t.destinations.rio.description}</p>
            <button class="flex items-center gap-2 text-secondary-fixed font-headline font-bold group"
            >
              {t.destinations.rio.cta}
              <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
            </button>
          </div>
        </div>
        <!-- Amazon + Iguazu -->
        <div class="md:col-span-5 grid grid-rows-2 gap-6">
          <div class="relative group overflow-hidden rounded-xl editorial-shadow">
            <img
              alt="Dense Amazon rainforest with exotic wildlife"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              src={`${base}images/amazonian.png`}
            />
            <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8">
              <span class="text-secondary-fixed font-headline font-bold text-xs uppercase tracking-widest mb-2 block">{t.destinations.amazon.tag}</span>
              <h3 class="text-2xl font-headline font-bold text-white">{t.destinations.amazon.title}</h3>
            </div>
          </div>
          <div class="bg-surface-container-highest p-10 rounded-xl relative overflow-hidden flex flex-col justify-center">
            <div class="relative z-10">
              <span class="text-tertiary font-headline font-bold text-xs uppercase tracking-widest mb-4 block">{t.destinations.stats.subtitle}</span>
              <h3 class="text-3xl font-headline font-bold text-on-surface mb-4">{t.destinations.stats.title}</h3>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <div class="text-2xl font-headline font-extrabold text-primary">7,491</div>
                  <div class="text-xs text-on-surface-variant font-label font-bold uppercase tracking-wide">{t.destinations.stats.coastline}</div>
                </div>
                <div>
                  <div class="text-2xl font-headline font-extrabold text-primary">2,500+</div>
                  <div class="text-xs text-on-surface-variant font-label font-bold uppercase tracking-wide">{t.destinations.stats.beaches}</div>
                </div>
                <div>
                  <div class="text-2xl font-headline font-extrabold text-primary">72</div>
                  <div class="text-xs text-on-surface-variant font-label font-bold uppercase tracking-wide">{t.destinations.stats.parks}</div>
                </div>
                <div>
                  <div class="text-2xl font-headline font-extrabold text-primary">23</div>
                  <div class="text-xs text-on-surface-variant font-label font-bold uppercase tracking-wide">{t.destinations.stats.unesco}</div>
                </div>
              </div>
            </div>
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-secondary-container/20 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Regional Highlights -->
  <section class="py-24 px-6 bg-surface-container-low overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="text-tertiary font-headline font-bold tracking-widest text-sm uppercase mb-6 block">{t.destinations.regions.subtitle}</span>
        <h2 class="text-5xl md:text-6xl font-headline font-extrabold text-on-surface mb-4 leading-tight">{t.destinations.regions.title}</h2>
        <p class="text-xl text-on-surface-variant max-w-2xl">{t.destinations.regions.description}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Northeast -->
        <div class="group relative overflow-hidden rounded-xl h-[480px] editorial-shadow">
          <img
            alt="Spicy Northeastern Brazilian coastal landscape"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src={`${base}images/northeastern.png`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-secondary-container/80 backdrop-blur-md text-on-secondary-container px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">{t.destinations.regions.northeast.tag}</span>
            </div>
            <h3 class="text-3xl font-headline font-bold text-white mb-2">{t.destinations.regions.northeast.title}</h3>
            <p class="text-white/80 text-sm mb-4">{t.destinations.regions.northeast.description}</p>
            <div class="flex items-center gap-4 text-sm">
              <span class="flex items-center gap-1 text-secondary-fixed">
                <span class="material-symbols-outlined text-base">wb_sunny</span> {t.destinations.regions.northeast.detail}
              </span>
            </div>
          </div>
        </div>
        <!-- South -->
        <div class="group relative overflow-hidden rounded-xl h-[480px] editorial-shadow">
          <img
            alt="Southern Brazilian Churrasco gaucho tradition"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src={`${base}images/southern-churrasco.png`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-tertiary-container/80 backdrop-blur-md text-on-tertiary-container px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">{t.destinations.regions.south.tag}</span>
            </div>
            <h3 class="text-3xl font-headline font-bold text-white mb-2">{t.destinations.regions.south.title}</h3>
            <p class="text-white/80 text-sm mb-4">{t.destinations.regions.south.description}</p>
            <div class="flex items-center gap-4 text-sm">
              <span class="flex items-center gap-1 text-secondary-fixed">
                <span class="material-symbols-outlined text-base">landscape</span> {t.destinations.regions.south.detail}
              </span>
            </div>
          </div>
        </div>
        <!-- Southeast -->
        <div class="group relative overflow-hidden rounded-xl h-[480px] editorial-shadow">
          <img
            alt="Christ the Redeemer overlooking the city at sunset"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            src={`${base}images/hero-christ.png`}
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-8 w-full">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-primary-container/80 backdrop-blur-md text-on-primary-container px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">{t.destinations.regions.southeast.tag}</span>
            </div>
            <h3 class="text-3xl font-headline font-bold text-white mb-2">{t.destinations.regions.southeast.title}</h3>
            <p class="text-white/80 text-sm mb-4">{t.destinations.regions.southeast.description}</p>
            <div class="flex items-center gap-4 text-sm">
              <span class="flex items-center gap-1 text-secondary-fixed">
                <span class="material-symbols-outlined text-base">location_city</span> {t.destinations.regions.southeast.detail}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Editorial: Minas Gerais Deep-Dive -->
  <section class="py-24 px-6 overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div class="relative">
          <div class="aspect-[4/5] rounded-xl overflow-hidden editorial-shadow">
            <img
              alt="Brazilian artisanal cheese and Pão de Queijo from Minas Gerais"
              class="w-full h-full object-cover"
              src={`${base}images/minas-cheese.png`}
            />
          </div>
          <div class="absolute -bottom-10 -right-10 w-64 h-64 glass-effect p-8 rounded-xl editorial-shadow hidden md:block">
            <span class="material-symbols-outlined text-primary text-4xl mb-4" style="font-variation-settings: 'FILL' 1;">hiking</span>
            <h4 class="font-headline font-bold text-xl mb-2">{t.destinations.minas.cardTitle}</h4>
            <p class="text-sm text-on-surface-variant">{t.destinations.minas.cardDescription}</p>
          </div>
        </div>
        <div>
          <span class="text-tertiary font-headline font-bold tracking-widest text-sm uppercase mb-6 block">{t.destinations.minas.subtitle}</span>
          <h2 class="text-5xl md:text-6xl font-headline font-extrabold text-on-surface mb-8 leading-tight">{t.destinations.minas.title}</h2>
          <p class="text-xl text-on-surface-variant font-body leading-relaxed mb-10">
            {t.destinations.minas.description}
          </p>
          <div class="grid grid-cols-2 gap-8">
            <div>
              <div class="text-4xl font-headline font-extrabold text-primary mb-2">12</div>
              <div class="font-label font-bold text-on-surface-variant uppercase tracking-wide text-xs">{t.destinations.minas.unescoCities}</div>
            </div>
            <div>
              <div class="text-4xl font-headline font-extrabold text-primary mb-2">#1</div>
              <div class="font-label font-bold text-on-surface-variant uppercase tracking-wide text-xs">{t.destinations.minas.coffeeProducer}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang={currentLang} />
</Layout>
