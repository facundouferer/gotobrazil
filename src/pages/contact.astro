---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<Layout title="Brazil - Contact">
  <Navbar variant="glass-pill" />

  <!-- Hero -->
  <header class="relative pt-32 pb-20 px-6 overflow-hidden">
    <div class="max-w-7xl mx-auto text-center">
      <span class="text-primary font-headline font-bold tracking-widest text-sm uppercase mb-4 block">Get in Touch</span>
      <h1 class="font-headline font-extrabold text-5xl md:text-7xl text-on-surface tracking-tighter leading-tight mb-6">Let's Plan Your<br /><span class="text-primary">Brazilian Adventure</span></h1>
      <p class="text-xl text-on-surface-variant max-w-2xl mx-auto">Have a question about our destinations, culture tours, or gastronomic experiences? We'd love to hear from you.</p>
    </div>
  </header>

  <!-- Contact Content -->
  <section class="pb-32 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Contact Form -->
      <div class="bg-surface-container rounded-2xl p-10 editorial-shadow">
        <h2 class="text-3xl font-headline font-extrabold text-on-surface mb-8">Send us a Message</h2>
        <form class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block font-label font-bold text-sm text-on-surface-variant mb-2 uppercase tracking-wide" for="name">Name</label>
              <input class="w-full bg-surface-container-lowest rounded-xl px-5 py-3.5 border border-outline-variant/30 text-on-surface focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="name" type="text" placeholder="Your name" />
            </div>
            <div>
              <label class="block font-label font-bold text-sm text-on-surface-variant mb-2 uppercase tracking-wide" for="email">Email</label>
              <input class="w-full bg-surface-container-lowest rounded-xl px-5 py-3.5 border border-outline-variant/30 text-on-surface focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="email" type="email" placeholder="you@email.com" />
            </div>
          </div>
          <div>
            <label class="block font-label font-bold text-sm text-on-surface-variant mb-2 uppercase tracking-wide" for="subject">Subject</label>
            <select class="w-full bg-surface-container-lowest rounded-xl px-5 py-3.5 border border-outline-variant/30 text-on-surface focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="subject">
              <option value="">Select a topic</option>
              <option value="destinations">Destinations</option>
              <option value="culture">Cultural Tours</option>
              <option value="gastronomy">Gastronomic Experiences</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="block font-label font-bold text-sm text-on-surface-variant mb-2 uppercase tracking-wide" for="message">Message</label>
            <textarea class="w-full bg-surface-container-lowest rounded-xl px-5 py-3.5 border border-outline-variant/30 text-on-surface focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-none" id="message" rows="5" placeholder="Tell us about your dream trip..."></textarea>
          </div>
          <button type="submit" class="w-full bg-primary text-on-primary font-headline font-bold text-lg py-4 rounded-full hover:scale-[1.02] transition-transform editorial-shadow">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="space-y-10">
        <div>
          <h2 class="text-3xl font-headline font-extrabold text-on-surface mb-8">Connect With Us</h2>
          <p class="text-lg text-on-surface-variant leading-relaxed">We're available across multiple channels. Follow our journey and reach out anytime — we respond within 24 hours.</p>
        </div>

        <!-- Social Links -->
        <div class="space-y-4">
          <a href="https://github.com/facundouferer" target="_blank" rel="noopener noreferrer" class="flex items-center gap-5 bg-surface-container rounded-xl p-6 editorial-shadow group hover:-translate-y-1 transition-transform duration-300">
            <div class="w-14 h-14 rounded-full bg-inverse-surface flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-inverse-on-surface text-2xl">code</span>
            </div>
            <div class="flex-1">
              <h4 class="font-headline font-bold text-lg text-on-surface group-hover:text-primary transition-colors">GitHub</h4>
              <p class="text-on-surface-variant text-sm">@facundouferer</p>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_outward</span>
          </a>

          <a href="https://www.linkedin.com/in/facundouferer/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-5 bg-surface-container rounded-xl p-6 editorial-shadow group hover:-translate-y-1 transition-transform duration-300">
            <div class="w-14 h-14 rounded-full bg-tertiary flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-on-tertiary text-2xl">work</span>
            </div>
            <div class="flex-1">
              <h4 class="font-headline font-bold text-lg text-on-surface group-hover:text-primary transition-colors">LinkedIn</h4>
              <p class="text-on-surface-variant text-sm">Facundo Uferer</p>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_outward</span>
          </a>

          <a href="https://www.instagram.com/facundouferer" target="_blank" rel="noopener noreferrer" class="flex items-center gap-5 bg-surface-container rounded-xl p-6 editorial-shadow group hover:-translate-y-1 transition-transform duration-300">
            <div class="w-14 h-14 rounded-full bg-secondary flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-on-secondary text-2xl">photo_camera</span>
            </div>
            <div class="flex-1">
              <h4 class="font-headline font-bold text-lg text-on-surface group-hover:text-primary transition-colors">Instagram</h4>
              <p class="text-on-surface-variant text-sm">@facundouferer</p>
            </div>
            <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary group-hover:translate-x-1 transition-all">arrow_outward</span>
          </a>
        </div>

        <!-- Info Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-surface-container-highest rounded-xl p-6">
            <span class="material-symbols-outlined text-primary text-2xl mb-3" style="font-variation-settings: 'FILL' 1;">schedule</span>
            <h4 class="font-headline font-bold text-on-surface mb-1">Response Time</h4>
            <p class="text-on-surface-variant text-sm">Within 24 hours</p>
          </div>
          <div class="bg-surface-container-highest rounded-xl p-6">
            <span class="material-symbols-outlined text-primary text-2xl mb-3" style="font-variation-settings: 'FILL' 1;">language</span>
            <h4 class="font-headline font-bold text-on-surface mb-1">Languages</h4>
            <p class="text-on-surface-variant text-sm">English, Spanish, Portuguese</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
