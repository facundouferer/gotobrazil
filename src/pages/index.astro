---
// Redirect to language-specific route based on cookie or default
// This runs client-side since we can't access cookies at build time
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting...</title>
    <script is:inline>
      (function() {
        const LANGUAGES = { ES: "es", PT: "pt", EN: "en" };
        const DEFAULT_LANGUAGE = LANGUAGES.ES;
        
        // Get saved language from cookie
        function getCookie(name) {
          const value = `; ${document.cookie}`;
          const parts = value.split(`; ${name}=`);
          if (parts.length === 2) return parts.pop().split(';').shift();
        }
        
        const savedLang = getCookie("user-language");
        let lang = DEFAULT_LANGUAGE;
        
        if (savedLang && Object.values(LANGUAGES).includes(savedLang)) {
          lang = savedLang;
        } else {
          // Detect from browser
          const browserLang = navigator.language || navigator.languages?.[0] || "";
          const langCode = browserLang.toLowerCase().split("-")[0];
          
          if (langCode === "pt") lang = LANGUAGES.PT;
          else if (langCode === "es") lang = LANGUAGES.ES;
          else if (langCode === "en") lang = LANGUAGES.EN;
        }
        
        // Redirect to language route
        window.location.replace(`/gotobrazil/${lang}/`);
      })();
    </script>
  </head>
  <body>
    <p>Redirecting...</p>
  </body>
</html>
