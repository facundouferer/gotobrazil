---
import { DEFAULT_LANGUAGE, type Language } from "../i18n/translations";

interface Props {
  title?: string;
  lang?: Language;
}

const { title = "Visit Brazil - High-end Tourism", lang = DEFAULT_LANGUAGE } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Language detection script - runs before page renders -->
    <script is:inline src={`${base}detect-language.js`}></script>
  </head>
  <body class="bg-surface text-on-surface font-body selection:bg-secondary-container selection:text-on-secondary-container">
    <slot />
  </body>
</html>
